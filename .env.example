# Local AI LLM Monitor / Portal
# Copy this file to .env and adjust for the host.

# Web/API bind settings. The orchestrator expects the monitor on port 8000.
PORT=8000
HOST=0.0.0.0

# Ollama native API. Keep this local unless the Ollama service is intentionally remote.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_REQUEST_TIMEOUT_MS=30000

# Persistent app configuration. Use an absolute path for production systemd installs.
CONFIG_PATH=./config/local-ai-llm.json

# Example only. Pick a model that is actually pulled on the target host.
DEFAULT_MODEL=qwen3:14b

# Pre-warm behavior. A pre-warm request asks Ollama to load the model without a real prompt.
PREWARM_DEFAULT_MODEL_ON_START=true
PREWARM_TIMEOUT_MS=120000
PREWARM_KEEP_ALIVE=-1

# GPU telemetry command timeout.
GPU_QUERY_TIMEOUT_MS=5000

# structured JSON log level: trace, debug, info, warn, error, fatal, silent.
LOG_LEVEL=info
